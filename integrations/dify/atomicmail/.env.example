# Dify plugin install mode for local/remote development.
# Use "remote" to connect this local plugin runtime to a hosted Dify workspace.
INSTALL_METHOD=remote

# Remote debug gateway host:port from your Dify workspace/plugin setup.
REMOTE_INSTALL_URL=debug.dify.ai:5003

# Secret remote install key generated by Dify for plugin remote debugging.
# Required for remote install/update. Keep it private.
REMOTE_INSTALL_KEY=********-****-****-****-************
